# ─────────────────────────────────────────────────────────────────────────────
#  AlphaAgent — local development environment
# ─────────────────────────────────────────────────────────────────────────────
#
# Usage
# -----
#   cp .env.example .env
#   # edit .env and fill in the values marked REQUIRED for the paths you use
#   make doctor          # validate your configuration
#   make run-mock        # offline dry-run, needs no keys
#   make run-real        # real LLM + local synthetic data  (needs OpenRouter)
#   make run-real-data   # real LLM + real Polygon data     (needs both keys)
#   make run-real-sql    # real LLM + Polygon + Postgres    (needs everything)
#
# Every variable below is read from the environment by the relevant module
# (see the file references in each section).  Nothing reads this file
# directly at runtime — the Makefile auto-loads .env for you; if you invoke
# scripts by hand, do:
#
#   set -a; source .env; set +a
#
# ---------------------------------------------------------------------------
# Safety
# ---------------------------------------------------------------------------
# * Never commit real secrets.  `.env` is in `.gitignore`.
# * Leave a field blank (or delete the line) to fall back to the code default.
# * Tests never require real keys; CI runs in mock mode by default.
# ---------------------------------------------------------------------------


# ═════════════════════════════════════════════════════════════════════════════
#  LLM provider — OpenRouter
#  Used by: alpha_harness/llm/config.py  (OpenRouterConfig.from_env)
#  Required for: real LLM mode (proposer, autonomous cycle without --mock-llm)
# ═════════════════════════════════════════════════════════════════════════════

# REQUIRED for any real-LLM run.  Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# REQUIRED — choose a model available in your OpenRouter region.
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_TIMEOUT=60

# Optional attribution headers OpenRouter surfaces in their dashboard.
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=AlphaAgent-local


# ═════════════════════════════════════════════════════════════════════════════
#  Market data — Polygon.io (US equities)
#  Used by: alpha_harness/data/polygon_equities.py
#  Required for: --data-source polygon in scripts/run_research_cycle.py
#                (the synthetic and parquet sources need no key)
# ═════════════════════════════════════════════════════════════════════════════

# REQUIRED only when requesting live equity bars from Polygon.
# Get a key at https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=


# ═════════════════════════════════════════════════════════════════════════════
#  Persistence — Postgres (optional, SQL backend only)
#  Used by: alpha_harness/config.py (PostgresSettings.from_env)
#           alpha_harness/db/connection.py
#  Required for: ALPHA_AGENT_BACKEND=sql  or  --backend sql on scripts
#                (the default in-memory backend needs none of this)
#  These defaults line up with docker-compose.yml so `make db-up` works
#  out of the box.
# ═════════════════════════════════════════════════════════════════════════════

POSTGRES_USER=alphaagent
POSTGRES_PASSWORD=alphaagent_dev
POSTGRES_DB=alphaagent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional — a full SQLAlchemy URL.  If set, it takes precedence over the
# individual POSTGRES_* values above.  Leave blank for the default
# docker-compose setup.
# DATABASE_URL=postgresql+psycopg://alphaagent:alphaagent_dev@localhost:5432/alphaagent


# ═════════════════════════════════════════════════════════════════════════════
#  Round 4A.1 guardrails — per-cycle LLM budget  (all OPTIONAL)
#  Used by: scripts/autonomous_cycle.py  +  alpha_harness/llm/budget.py
#  Leave blank to disable enforcement (calls still get logged either way).
# ═════════════════════════════════════════════════════════════════════════════

# Hard cap on cumulative total_tokens for a single cycle.  Recommended
# starting point: 50 000.  The cycle aborts with a typed error when the
# next call would push the ledger above this value.
ALPHA_AGENT_TOKEN_BUDGET=50000

# Hard cap in USD per cycle.  Set this *and* the two *_COST_PER_1K rates
# below for dollar-based enforcement.  Leave blank if you only want the
# token cap.
ALPHA_AGENT_COST_BUDGET_USD=0.50

# Per-1K-token rates used to price the cost ledger.  Defaults below
# track anthropic/claude-sonnet-4.6 on OpenRouter as of April 2026 —
# adjust for your actual model before relying on cost enforcement.
ALPHA_AGENT_PROMPT_COST_PER_1K=0.003
ALPHA_AGENT_COMPLETION_COST_PER_1K=0.015

# Override the JSONL log directory (default: artifacts/llm_calls/).
# ALPHA_AGENT_LLM_LOG_DIR=artifacts/llm_calls


# ═════════════════════════════════════════════════════════════════════════════
#  Round 4A.1 guardrails — Polygon pacing  (OPTIONAL)
#  Used by: alpha_harness/data/rate_limit.py
# ═════════════════════════════════════════════════════════════════════════════

# Requests per minute the Polygon loader paces itself at.  The free tier
# is ~5 rpm; raise this only if your key is paid.
POLYGON_RPM=5


# ═════════════════════════════════════════════════════════════════════════════
#  Mode selection
# ═════════════════════════════════════════════════════════════════════════════

# Default persistence backend when a script is invoked without --backend.
# One of: memory | sql
ALPHA_AGENT_BACKEND=memory

# Default data source for scripts that support it.
# One of: synthetic | parquet | polygon
# (scripts accept --data-source to override this per invocation)
ALPHA_AGENT_DATA_SOURCE=synthetic
