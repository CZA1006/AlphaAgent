# --------------------------------------------------
# AlphaAgent local development environment
# Copy to .env and fill in real values where needed.
# --------------------------------------------------

# ── Postgres (docker-compose + alpha_harness.db) ──
POSTGRES_USER=alphaagent
POSTGRES_PASSWORD=alphaagent_dev
POSTGRES_DB=alphaagent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Market data ──────────────────────────────────
# Polygon.io — US equity bars (leave blank to use local sample data)
POLYGON_API_KEY=

# ── LLM providers ───────────────────────────────
# Not required for Milestone 1 deterministic evaluation.
# Will be used by Hermes runtime integration in later milestones.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
